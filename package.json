      "import": {
        "types": "./dist/signature.d.ts",
        "default": "./dist/signature.js"
      }
    },
    "./counter": {
      "import": {
        "types": "./dist/counter.d.ts",
        "default": "./dist/counter.js"
      }
    },
    "./validate": {
      "import": {
        "types": "./dist/validate.d.ts",
