    "./criteria": {
      "import": {
        "types": "./dist/criteria.d.ts",
        "default": "./dist/criteria.js"
      }
    },
    "./events": {
      "import": {
        "types": "./dist/events.d.ts",
        "default": "./dist/events.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5",
    "viem": "^2.48.4"
